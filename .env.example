# Copy to .env and fill in. .env is gitignored.
# All values below have safe defaults baked into docker-compose.yml — only
# override what you need to change for your environment.

# Postgres credentials for the bundled `db` service. Change in production.
POSTGRES_PASSWORD=pergam

# Public-facing host/port that the server uses to build returned view URLs.
# Set these to whatever your users will type into a browser. If you put pergam
# behind a reverse proxy at https://pergam.example.com, set:
#   GRID_PUBLIC_HOST=pergam.example.com
#   GRID_PUBLIC_PORT=443
GRID_PUBLIC_HOST=localhost
GRID_PUBLIC_PORT=1111

# Host port the app binds to. Override if 1111 collides with something local.
PERGAM_PORT=1111

# Advanced: override the database the app connects to. Useful when pointing at
# an external Postgres instead of the bundled `db` service.
# GRID_DB_URL=postgresql://user:pass@host:5432/dbname
